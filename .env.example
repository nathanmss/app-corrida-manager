# Banco de dados PostgreSQL usado pela API e pelo Drizzle.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_corrida_manager

# API Express. Use uma porta diferente do frontend.
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# CORS. Para o deploy atual em host unico, pode ficar vazio porque frontend e API
# usam a mesma origem. Se houver frontend separado, liste as origens permitidas
# separadas por virgula, sempre sem barra final.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Ative apenas depois que o dominio definitivo estiver servindo HTTPS confiavel.
ENABLE_HSTS=false

# Produção: quando definido, a API também serve o build estático do frontend.
# No Dockerfile de produção, este valor já é configurado automaticamente.
PUBLIC_DIR=

# Frontend Vite. O vite.config.ts atual exige PORT e BASE_PATH no ambiente.
# Exemplo de execução local:
# PORT=5173 BASE_PATH=/ pnpm --filter @workspace/corrida-retorno-praia run dev
BASE_PATH=/

# OIDC/Replit permanece apenas como compatibilidade técnica legada.
# Para produção normal, deixe REPL_ID vazio e use o login admin local.
REPL_ID=
ISSUER_URL=https://replit.com/oidc

# Admin local/produção. Usado pelo seed de admin; nunca use estes valores padrão em produção.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Organização
